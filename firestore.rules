rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow public access to specifically designated collections
    match /listings/{id} { allow read: if true; }
    match /price_history/{id} { allow read: if true; }
    match /market_snapshots/{id} { allow read: if true; }
    match /price_changes/{id} { allow read: if true; }
    match /scrape_runs/{id} { allow read: if true; }
    match /day_of_week_prices/{id} { allow read: if true; }
    match /week_of_month_prices/{id} { allow read: if true; }
    match /sold_estimates/{id} { allow read: if true; }
    
    // Everything else is locked down by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}